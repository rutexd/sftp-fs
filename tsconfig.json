{
    "compilerOptions": {
        "target": "ES2019",
        "module": "commonjs",
        "lib": ["ES2019"],
        "types": ["node"],
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": false,
        "baseUrl": ".",
        "ignoreDeprecations": "6.0"
    },
    "include": [
        "types-test/**/*.ts"
    ]
}
